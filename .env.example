NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
REPORT_ACTION_SECRET=

# ── WooCommerce — payment-link bridge (server-side only) ──────────────────
# Saving a new order from /orders/new calls /api/orders/[id]/create-payment-link
# which mirrors the order into WooCommerce as 'pending' and returns the WC
# payment_url. The customer's browser then runs through PayPlus via the
# WooCommerce checkout (the PayPlus plugin is wired in WordPress).
#
# Generate the consumer key/secret in WordPress admin →
# WooCommerce → Settings → Advanced → REST API. Permission: Read/Write.
# Server-side only — NEVER expose via NEXT_PUBLIC_ vars.
#
# Payment confirmation stays MANUAL on the CRM order card (operator flips
# סטטוס_תשלום to שולם). No webhook, no auto-receipt, no auto-deduction.
WOOCOMMERCE_SITE_URL=https://adipatifur.co.il
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# WooCommerce webhook signature secret (HMAC-SHA256, base64).
# Configure the SAME value in WordPress admin →
# WooCommerce → Settings → Advanced → Webhooks → (your webhook) → Secret.
# /api/webhooks/woocommerce-order verifies X-WC-Webhook-Signature against
# this secret. If unset, the route rejects every request with 503.
# Server-side only.
WC_WEBHOOK_SECRET=
# Optional fallback. Leave EMPTY to use fee_lines (no product needed).
# Set to a real WC product id only if your storefront enforces that every
# order must carry a product (some plugins/extensions do). The product can
# be a private "תשלום CRM" SKU.
# WOOCOMMERCE_PAYMENT_PRODUCT_ID=

# Public app origin (used by other features — courier links, satmar emails).
NEXT_PUBLIC_BASE_URL=https://your-app.example.com

# ── PayPlus DIRECT payment links (server-side only) ──────────────────────────
# /api/orders/[id]/create-payment-link calls the PayPlus REST API
# (PaymentPages/generateLink) and returns a DIRECT payments.payplus.co.il
# link — it does NOT route through WooCommerce. Get these from the PayPlus
# dashboard. Server-side only — NEVER expose via NEXT_PUBLIC_ vars.
# Payment confirmation stays MANUAL — operator flips סטטוס_תשלום to שולם.
PAYPLUS_API_KEY=
PAYPLUS_SECRET_KEY=
PAYPLUS_PAGE_UID=
PAYPLUS_API_URL=https://restapi.payplus.co.il

# ── PayPlus static payment link (public — safe to expose to browser) ─────────
# A fixed PayPlus payment page created with amount=0, used by the manual
# "תשלום PayPlus" modal (PayPlusModal). The CRM shows the remaining balance
# and lets the operator copy it before opening this fixed link.
NEXT_PUBLIC_PAYPLUS_STATIC_PAYMENT_LINK=https://payments.payplus.co.il/1b03306e-c3b4-46f0-b1f4-9290f6a7f3c2

# ── Website order alert email ──────────────────────────────────────────────
# Recipient for the internal admin alert sent when a new WooCommerce order
# arrives via the webhook. Defaults to the hardcoded owner email in
# src/lib/admin-alert-email.ts if this var is not set.
# Server-side only.
MANAGER_NOTIFICATION_EMAIL=
