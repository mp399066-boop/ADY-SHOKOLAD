NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
REPORT_ACTION_SECRET=

# ── WooCommerce — INBOUND website-order import webhook only ────────────────
# CRM payment links are now PayPlus-DIRECT (see the PayPlus section below);
# the CRM no longer creates WooCommerce orders or returns order-pay URLs.
# WooCommerce is kept ONLY to import new website orders into the CRM via the
# inbound webhook /api/webhooks/woocommerce-order.
#
# WooCommerce webhook signature secret (HMAC-SHA256, base64).
# Configure the SAME value in WordPress admin →
# WooCommerce → Settings → Advanced → Webhooks → (your webhook) → Secret.
# /api/webhooks/woocommerce-order verifies X-WC-Webhook-Signature against
# this secret. If unset, the route rejects every request with 503.
# Server-side only.
WC_WEBHOOK_SECRET=
#
# DEPRECATED — no longer used by any code. These powered the old WooCommerce
# payment-link bridge (CRM → WC order → order-pay URL), which has been removed
# in favor of PayPlus-direct. Safe to delete from your environment; kept here
# only as a migration note. The inbound import webhook above does NOT use them.
# WOOCOMMERCE_SITE_URL=https://adipatifur.co.il
# WOOCOMMERCE_CONSUMER_KEY=
# WOOCOMMERCE_CONSUMER_SECRET=
# WOOCOMMERCE_PAYMENT_PRODUCT_ID=

# Public app origin (used by other features — courier links, satmar emails).
NEXT_PUBLIC_BASE_URL=https://your-app.example.com

# ── PayPlus DIRECT payment links (server-side only) ──────────────────────────
# /api/orders/[id]/create-payment-link calls the PayPlus REST API
# (PaymentPages/generateLink) and returns a DIRECT payments.payplus.co.il
# link — it does NOT route through WooCommerce. Get these from the PayPlus
# dashboard. Server-side only — NEVER expose via NEXT_PUBLIC_ vars.
# Payment confirmation stays MANUAL — operator flips סטטוס_תשלום to שולם.
PAYPLUS_API_KEY=
PAYPLUS_SECRET_KEY=
PAYPLUS_PAGE_UID=
PAYPLUS_API_URL=https://restapi.payplus.co.il
# Optional. Minutes the generated PayPlus link stays valid BEFORE payment
# (max wait window — NOT permission to reuse the link), sent as `expiry_datetime`
# on generateLink. If unset we default to 1440 (24 hours). Without this the link
# uses the PayPlus PAGE_UID's own setting, whose default is ~30 min — which
# caused the "תוקף דף התשלום פג" expired-page error.
PAYPLUS_LINK_EXPIRY_MINUTES=1440
# Gate for the API-generated per-order link button on the order page. The
# account currently lacks REST API permission (generateLink returns HTTP 422
# "THIS COMPANY DONT HAVE THE PERMISSION TO USE THE API"), so the button is
# HIDDEN by default. Set to 'true' only once PayPlus enables API access.
NEXT_PUBLIC_PAYPLUS_API_ENABLED=false

# ── PayPlus static payment link (public — safe to expose to browser) ─────────
# A fixed PayPlus payment page (amount=0 / open amount) where the customer
# fills in name, phone, order number and amount manually. The order page's
# "פתח דף תשלום PayPlus" button opens this link. This is the temporary,
# non-API PayPlus flow used while REST API access is not yet enabled.
NEXT_PUBLIC_PAYPLUS_STATIC_PAYMENT_LINK=https://payments.payplus.co.il/1b03306e-c3b4-46f0-b1f4-9290f6a7f3c2

# ── Website order alert email ──────────────────────────────────────────────
# Recipient for the internal admin alert sent when a new WooCommerce order
# arrives via the webhook. Defaults to the hardcoded owner email in
# src/lib/admin-alert-email.ts if this var is not set.
# Server-side only.
MANAGER_NOTIFICATION_EMAIL=
