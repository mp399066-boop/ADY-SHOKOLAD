NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
REPORT_ACTION_SECRET=

# ── WooCommerce — payment-link bridge (server-side only) ──────────────────
# Saving a new order from /orders/new calls /api/orders/[id]/create-payment-link
# which mirrors the order into WooCommerce as 'pending' and returns the WC
# payment_url. The customer's browser then runs through PayPlus via the
# WooCommerce checkout (the PayPlus plugin is wired in WordPress).
#
# Generate the consumer key/secret in WordPress admin →
# WooCommerce → Settings → Advanced → REST API. Permission: Read/Write.
# Server-side only — NEVER expose via NEXT_PUBLIC_ vars.
#
# Payment confirmation stays MANUAL on the CRM order card (operator flips
# סטטוס_תשלום to שולם). No webhook, no auto-receipt, no auto-deduction.
WOOCOMMERCE_SITE_URL=https://adipatifur.co.il
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
# Optional fallback. Leave EMPTY to use fee_lines (no product needed).
# Set to a real WC product id only if your storefront enforces that every
# order must carry a product (some plugins/extensions do). The product can
# be a private "תשלום CRM" SKU.
# WOOCOMMERCE_PAYMENT_PRODUCT_ID=

# Public app origin (used by other features — courier links, satmar emails).
NEXT_PUBLIC_BASE_URL=https://your-app.example.com
