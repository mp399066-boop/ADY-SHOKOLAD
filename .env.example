NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
REPORT_ACTION_SECRET=

# ── PayPlus — generate per-order payment link (server-side only) ──────────
# Saving a new order from /orders/new calls /api/orders/[id]/create-payment-link
# which uses these credentials to mint a payment-page URL for the order
# total. The API key and secret stay on the server — they are NOT exposed
# via NEXT_PUBLIC_ vars. The browser only receives the resulting URL.
#
# Payment confirmation stays MANUAL on the order card (operator flips
# סטטוס_תשלום to שולם). No webhook, no auto-receipt, no auto-deduction.
PAYPLUS_API_KEY=
PAYPLUS_SECRET_KEY=
PAYPLUS_PAYMENT_PAGE_UID=
# Optional — defaults to https://restapi.payplus.co.il
# PAYPLUS_API_URL=https://restapi.payplus.co.il
# Public app origin used by PayPlus for refURL_success / refURL_failure.
NEXT_PUBLIC_BASE_URL=https://your-app.example.com
